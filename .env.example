# 環境設定
NODE_ENV=development
PORT=3001

# 資料庫連線
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT 認證
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 前端 URL（CORS 主來源，必填邏輯同後端）
FRONTEND_URL=http://localhost:3000

# 額外允許的瀏覽器來源（逗號分隔，勿加尾隨斜線）。例：Vercel Preview、第二網域
# FRONTEND_ORIGINS_EXTRA=https://xxx.vercel.app,https://app.example.com

# 種子／ensure-admin 超級管理員登入帳號（預設 admin，非 Email）
# SEED_ADMIN_USERNAME=admin

# 種子腳本管理員密碼（未設定時使用專案約定預設；正式環境請務必設定強密碼並旋轉）
# SEED_ADMIN_PASSWORD=

# Vercel（僅本機/CI 查部署用，勿提交真 token）
# VERCEL_TOKEN=
# VERCEL_FRONTEND_PROJECT_ID=
# VERCEL_TEAM_ID=

# 郵件發送（預留）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# 檔案上傳（預留）
# UPLOAD_MAX_SIZE=5242880
# UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf