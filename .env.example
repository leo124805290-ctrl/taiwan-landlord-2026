# 若 API 要求 team：VERCEL_TEAM_ID=

# 郵件發送（預留）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# 檔案上傳（預留）
# UPLOAD_MAX_SIZE=5242880
# UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf