{
  "name": "taiwan-landlord-backend-v2",
  "version": "2.0.0",
  "description": "台灣房東越南租客管理系統後端 API v2.0 - TypeScript + Drizzle ORM",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "taiwan-landlord",
    "vietnam-tenant",
    "property-management",
    "drizzle-orm",
    "typescript"
  ],
  "author": "OpenClaw Assistant",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.37.0",
    "postgres": "^3.4.4",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "tsx": "^4.19.2",
    "drizzle-kit": "^0.28.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}