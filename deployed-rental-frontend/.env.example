# ============================================
# 台灣房東越南租客管理系統前端 v2.0
# 環境變數設定檔
# ============================================

# 執行環境
NODE_ENV=development

# 後端 API URL
# 開發環境可指向本機或 Zeabur，部署到 Vercel 時請在專案環境變數中設定相同鍵值
NEXT_PUBLIC_API_URL=https://taiwan-landlord-2026.zeabur.app

# 應用設定
NEXT_PUBLIC_APP_NAME=台灣房東越南租客管理系統
NEXT_PUBLIC_APP_VERSION=2.0.0

# 多語言設定
NEXT_PUBLIC_DEFAULT_LOCALE=zh-TW
NEXT_PUBLIC_SUPPORTED_LOCALES=zh-TW,vi-VN

# 功能開關
NEXT_PUBLIC_FEATURE_MAINTENANCE=false
NEXT_PUBLIC_FEATURE_REGISTRATION=true
NEXT_PUBLIC_FEATURE_MULTI_LANGUAGE=true

# 地圖 API（預留）
# NEXT_PUBLIC_MAP_PROVIDER=google
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# 分析工具（預留）
# NEXT_PUBLIC_GA_TRACKING_ID=UA-XXXXX-Y
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# 上傳設定（預留）
# NEXT_PUBLIC_UPLOAD_MAX_SIZE=5242880
# NEXT_PUBLIC_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# 除錯模式
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_LOG_LEVEL=info

# ============================================
# 注意事項：
# 1. 複製此檔案為 .env.local 進行本地開發
# 2. 生產環境變數請設定在 Vercel 環境變數中
# 3. 含有 NEXT_PUBLIC_ 前綴的變數會在前端暴露
# 4. 敏感資訊請勿使用 NEXT_PUBLIC_ 前綴
# ============================================